# Development vs production:
# In development, VITE_BASE_URL is usually a reachable local backend URL like http://127.0.0.1:8001,
# while VITE_SITE_NAME stays the real Frappe site name such as with-sai-coding.local.
# In production, these are often the same public host, and the socket/site ports are usually 80 or 443.
VITE_BASE_URL="http://127.0.0.1:8001" # Reachable backend URL from the frontend dev server/browser.
VITE_SOCKET_PORT=5174 # Local Vite dev server port. In production this is usually 80 or 443.
VITE_SITE_NAME="<sitename>" # Actual Frappe site name. This can differ from VITE_BASE_URL in development.
VITE_ENABLE_SOCKET=true
VITE_SITE_PORT=8001 # Frappe backend port in development. In production this is usually 80 or 443.
