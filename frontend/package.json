{
  "name": "frappe-ui-react-starter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "pnpm": ">=10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "pnpm --filter app lint",
    "format": "pnpm --filter app format",
    "dev": "pnpm --filter app dev",
    "check-types": "pnpm --filter app check-types",
    "build": "pnpm --filter app build",
    "serve": "pnpm --filter app preview",
    "preview-storybook": "pnpm --filter storybook-config preview-storybook",
    "storybook": "pnpm --filter storybook-config storybook",
    "test": "pnpm --filter app test",
    "test:e2e": "pnpm --filter app test:e2e",
    "test:e2e-ui": "pnpm --filter app test:e2e-ui"
  },
  "workspaces": [
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "ajv@<6.14.0": "^6.14.0",
      "axios@>=1.0.0 <=1.13.4": "^1.13.5",
      "dompurify": "^3.3.2",
      "flatted": "^3.4.2",
      "markdown-it@>=13.0.0 <14.1.1": "^14.1.1",
      "minimatch@<3.1.3": ">=3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "socket.io-parser": "^4.2.6"
    }
  },
  "dependencies": {
    "frappe-react-sdk": "^1.14.0"
  }
}
